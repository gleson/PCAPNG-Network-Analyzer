# PCAP Analyzer — environment configuration.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# is NOT baked into the Docker image — never commit real secrets.
#   cp .env.example .env
#
# Generate a strong secret: python -c "import secrets;print(secrets.token_urlsafe(24))"

# --- PostgreSQL --------------------------------------------------------------
# POSTGRES_PASSWORD is REQUIRED: docker compose refuses to start without it.
POSTGRES_USER=pcap_user
POSTGRES_PASSWORD=
POSTGRES_DB=pcap_analyzer

# --- Redis (Celery broker) ---------------------------------------------------
# REQUIRED: the broker is password-protected (--requirepass).
REDIS_PASSWORD=

# --- Flask -------------------------------------------------------------------
# Session signing key. Without it, sessions reset on every restart.
# Generate: python -c "import secrets;print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Set to 1 ONLY when the app is served over HTTPS (e.g. a TLS-terminating
# reverse proxy in front). Over plain HTTP a Secure cookie is withheld by the
# browser and login breaks. Leave empty for the default HTTP docker-compose.
SESSION_COOKIE_SECURE=

# Initial admin password. If empty, a random one is printed to the web
# container log on first boot (and must be changed on first login).
PCAP_DEFAULT_ADMIN_PASSWORD=

# --- Optional integrations ---------------------------------------------------
# AbuseIPDB threat-intel API key (leave empty to disable).
ABUSEIPDB_API_KEY=

# --- Optional tuning / escape hatches ----------------------------------------
# Number of trusted reverse proxies in front of the app. 0 = trust none
# (X-Forwarded-* ignored). Set to the proxy hop count when behind nginx/etc.
# TRUSTED_PROXY_COUNT=0
# Session idle timeout in hours (default 12).
# SESSION_LIFETIME_HOURS=12
# Set to 1 to disable the Swagger UI / OpenAPI spec at /apidocs.
# DISABLE_SWAGGER=
# Set to 1 to allow webhooks to target private/loopback IPs (off = SSRF guard).
# PCAP_ALLOW_PRIVATE_WEBHOOKS=
# Max accepted upload size in bytes (default 10 GiB).
# MAX_UPLOAD_BYTES=10737418240
# Gunicorn tuning.
# GUNICORN_THREADS=8
# GUNICORN_TIMEOUT=120
# Postgres connection pool size, PER PROCESS. DB_POOL_MAX must be >= the number
# of concurrent DB users in one process: GUNICORN_THREADS for the web container,
# or the Celery --concurrency for a worker. Raise it in lockstep if you raise
# those. Total connections across all containers (web + celery workers + beat)
# stay well under Postgres' default max_connections=100 because each prefork
# Celery child is single-threaded and only opens one.
# DB_POOL_MIN=1
# DB_POOL_MAX=10
# Packet-viewer index cache: number of distinct scans whose parsed packet
# summaries are kept in memory (process-global, so it relies on web workers=1).
# Each cached scan holds up to ~100k compact dicts; raise only if you routinely
# page through several different scans at once.
# PKT_INDEX_CACHE_SIZE=3
